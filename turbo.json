{
	"$schema": "https://turbo.build/schema.json",
	"globalEnv": ["AGENTOS_SKIP_NATIVE_META_BUILD"],
	"globalDependencies": [
		"crates/sidecar-protocol/protocol/**",
		"packages/build-tools/scripts/compile-sidecar-protocol.mjs"
	],
	"tasks": {
		"//#fmt": {
			"cache": false
		},
		"build": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**",
				"tsconfig.json",
				"package.json"
			],
			"outputs": ["dist/**"]
		},
		"check-types": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**",
				"tests/**",
				"tsconfig.json",
				"package.json"
			]
		},
		"test": {
			"inputs": [
				"src/**",
				"tests/**",
				"software/**/test/**",
				"native/tests/**",
				"scripts/**",
				"package.json"
			],
			"dependsOn": ["^build", "check-types"]
		},
		"@rivet-dev/agentos-sidecar#build": {
			"cache": false
		},
		"@rivet-dev/agentos-runtime-core#build": {
			"dependsOn": ["^build"],
			"inputs": [
				"src/**",
				"scripts/**",
				"tsconfig.json",
				"package.json"
			],
			"outputs": ["dist/**", "commands/**"]
		},
		"@rivet-dev/agentos-plugin#build": {
			"cache": false
		}
	}
}
