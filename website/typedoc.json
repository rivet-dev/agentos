{
	"$schema": "https://typedoc.org/schema.json",
	"entryPoints": [
		"../packages/agentos/src/index.ts",
		"../packages/javascript/src/index.ts",
		"../packages/python/src/index.ts"
	],
	"tsconfig": "./tsconfig.typedoc.json",
	"out": "public/api",
	"name": "agentOS API Reference",
	"includeVersion": true,
	"hideGenerator": true,
	"skipErrorChecking": true,
	"readme": "none",
	"githubPages": false,
