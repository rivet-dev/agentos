---
import { InkChip } from "../editorial/InkPanel";

// The "1. Install" row on a registry detail page: the install command in an
// InkChip with a Copy button beside it. The button reuses the site's ghost
// button idiom (white surface, hairline ink border, Copy icon, label) so it
// reads like the "Read the Docs" and self-host buttons rather than a bare
// outlined box. The copy behavior is wired in [slug].astro's script, keyed off
// data-copy-command; it toggles the label span and swaps the two icons.
interface Props {
	command: string;
	class?: string;
}

const { command, class: className } = Astro.props;
---

<div class:list={["flex items-stretch gap-3", className]}>
	<InkChip command={command} className="min-w-0 flex-1" />
	<button
		type="button"
		data-copy-command={command}
		class="inline-flex shrink-0 cursor-pointer items-center justify-center gap-2 whitespace-nowrap rounded-md border border-ink/15 bg-white px-4 text-sm font-medium text-ink-soft transition-colors hover:border-ink/40 hover:bg-ink/[0.02] hover:text-ink"
	>
		<svg
			data-copy-icon="copy"
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
			class="h-4 w-4"
		>
			<rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect>
			<path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path>
		</svg>
		<svg
			data-copy-icon="check"
			xmlns="http://www.w3.org/2000/svg"
			width="16"
			height="16"
			viewBox="0 0 24 24"
			fill="none"
			stroke="currentColor"
			stroke-width="2"
			stroke-linecap="round"
			stroke-linejoin="round"
			aria-hidden="true"
			class="hidden h-4 w-4 text-pine"
		>
			<path d="M20 6 9 17l-5-5"></path>
		</svg>
		{/* Reserve the width of the longest label so the button doesn't resize
		    on copy and shove the flex-1 chip. Same trick as SetupWithAgent. */}
		<span class="grid place-items-center">
			<span class="invisible col-start-1 row-start-1" aria-hidden="true">Copied</span>
			<span data-copy-label class="col-start-1 row-start-1">Copy</span>
		</span>
	</button>
</div>
