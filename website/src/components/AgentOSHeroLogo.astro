---
/**
 * Animated agentOS wordmark for the docs overview hero. Wraps the React
 * AnimatedAgentOSLogo (which fetches /images/agent-os/agentos-hero-logo-animated.svg
 * and animates its stroke/text/os layers) as a hydrated island. The docs pages
 * have no Tailwind utilities, so sizing is provided via a global style here
 * rather than the component's Tailwind className.
 */
import { AnimatedAgentOSLogo } from "./marketing/solutions/AgentOSPage";
---

<AnimatedAgentOSLogo client:load className="agentos-hero-anim" />

<style is:global>
	.agentos-hero-anim {
		height: 4.5rem;
		display: flex;
		align-items: center;
		justify-content: center;
	}
	.agentos-hero-anim svg {
		height: 100% !important;
		width: auto;
	}
</style>
