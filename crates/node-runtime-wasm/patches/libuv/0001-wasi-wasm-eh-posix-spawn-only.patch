Do not compile libuv's fork/exec child initializer when WebAssembly exceptions
make that fallback unreachable. AgentOS uses libuv's existing WASI
posix_spawn path, backed by the owned process syscall ABI.

diff --git a/src/unix/process.c b/src/unix/process.c
--- a/src/unix/process.c
+++ b/src/unix/process.c
@@ -294,6 +294,12 @@ static void uv__process_close_stream(uv_stdio_container_t* container) {
   uv__stream_close(container->data.stream);
 }
 
+/*
+ * The wasm-EH build cannot fork and uv__spawn_and_init_child_fork() returns
+ * UV_ENOSYS without referencing these helpers. Child creation stays on the
+ * POSIX posix_spawn(3) path backed by AgentOS's standard process syscall ABI.
+ */
+#if !(defined(__wasi__) && defined(__wasm_exception_handling__))
 
 static void uv__write_int(int fd, int val) {
   ssize_t n;
@@ -446,6 +452,7 @@ static void uv__process_child_init(const uv_process_options_t* options,
 
   uv__write_errno(error_fd);
 }
+#endif
 
 
 #if defined(__APPLE__) || defined(__wasi__)
