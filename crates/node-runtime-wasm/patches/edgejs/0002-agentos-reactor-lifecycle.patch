diff --git a/src/edge_agentos_reactor.cc b/src/edge_agentos_reactor.cc
new file mode 100644
index 0000000..7ac7a62
--- /dev/null
+++ b/src/edge_agentos_reactor.cc
@@ -0,0 +1,311 @@
+#include <array>
+#include <cstddef>
+#include <cstdint>
+#include <cstdlib>
+#include <cstring>
+#include <string>
+#include <utility>
+#include <vector>
+
+#include <uv.h>
+
+#include "edge_builtin_bytecode.h"
+#include "edge_cli.h"
+#include "edge_env_loop.h"
+#include "edge_environment.h"
+#include "edge_environment_runtime.h"
+#include "edge_napi_embedder_hooks.h"
+#include "edge_runtime.h"
+#include "edge_runtime_platform.h"
+#include "edge_worker_env.h"
+#include "unofficial_napi.h"
+
+namespace {
+
+constexpr size_t kMaxSourceBytes = 8 * 1024 * 1024;
+constexpr size_t kMaxErrorBytes = 64 * 1024;
+constexpr size_t kMaxOutstandingAllocationBytes = 8 * 1024 * 1024;
+constexpr size_t kMaxOutstandingAllocations = 32;
+
+enum class ReactorPhase : int32_t {
+  kEmpty = 0,
+  kCreated = 1,
+  kBootstrapped = 2,
+  kRunning = 3,
+  kInterrupted = 4,
+  kTearingDown = 5,
+};
+
+enum ReactorStatus : int32_t {
+  kOk = 0,
+  kInvalidArgument = -1,
+  kInvalidState = -2,
+  kEngineFailure = -3,
+  kScriptFailure = -4,
+  kInterrupted = -5,
+  kResourceLimit = -6,
+};
+
+struct ReactorAllocation {
+  uint8_t* pointer = nullptr;
+  uint32_t bytes = 0;
+};
+
+struct ReactorState {
+  ReactorPhase phase = ReactorPhase::kEmpty;
+  napi_env env = nullptr;
+  void* env_scope = nullptr;
+  std::string last_error;
+  std::array<ReactorAllocation, kMaxOutstandingAllocations> allocations = {};
+  size_t allocation_count = 0;
+  size_t allocated_bytes = 0;
+};
+
+ReactorState g_reactor;
+
+int32_t Fail(int32_t status, std::string error) {
+  if (error.size() > kMaxErrorBytes) error.resize(kMaxErrorBytes);
+  g_reactor.last_error = std::move(error);
+  return status;
+}
+
+bool ContainsAllocationRange(const uint8_t* pointer, uint32_t length) {
+  if (pointer == nullptr || length == 0) return false;
+  const uintptr_t start = reinterpret_cast<uintptr_t>(pointer);
+  for (size_t index = 0; index < g_reactor.allocation_count; ++index) {
+    const ReactorAllocation& allocation = g_reactor.allocations[index];
+    const uintptr_t allocation_start =
+        reinterpret_cast<uintptr_t>(allocation.pointer);
+    if (start >= allocation_start &&
+        start - allocation_start <= allocation.bytes &&
+        length <= allocation.bytes - (start - allocation_start)) {
+      return true;
+    }
+  }
+  return false;
+}
+
+bool CopySource(const uint8_t* bytes, uint32_t length, std::string* out) {
+  if (out == nullptr || bytes == nullptr || length == 0) return false;
+  if (length > kMaxSourceBytes) return false;
+  if (!ContainsAllocationRange(bytes, length)) return false;
+  out->assign(reinterpret_cast<const char*>(bytes), length);
+  return out->find('\0') == std::string::npos;
+}
+
+void ReleaseOutstandingAllocations() {
+  for (size_t index = 0; index < g_reactor.allocation_count; ++index) {
+    std::free(g_reactor.allocations[index].pointer);
+    g_reactor.allocations[index] = {};
+  }
+  g_reactor.allocation_count = 0;
+  g_reactor.allocated_bytes = 0;
+}
+
+void ResetState() {
+  g_reactor.phase = ReactorPhase::kEmpty;
+  g_reactor.env = nullptr;
+  g_reactor.env_scope = nullptr;
+}
+
+}  // namespace
+
+extern "C" {
+
+__attribute__((export_name("agentos_node_runtime_create")))
+int32_t AgentOsNodeRuntimeCreate() {
+  if (g_reactor.phase != ReactorPhase::kEmpty) {
+    return Fail(kInvalidState, "runtime create requires the empty state");
+  }
+
+  EdgeInitializeCliProcess();
+  EdgeInstallNapiEmbedderHooks();
+  std::vector<std::string> exec_argv;
+  std::string error;
+  if (!EdgeInitializeOpenSslForExecArgv(exec_argv, true, &error)) {
+    return Fail(kEngineFailure,
+                error.empty() ? "OpenSSL initialization failed" : std::move(error));
+  }
+
+  napi_env env = nullptr;
+  void* env_scope = nullptr;
+  const napi_status create_status = unofficial_napi_create_env(8, &env, &env_scope);
+  if (create_status != napi_ok || env == nullptr || env_scope == nullptr) {
+    return Fail(kEngineFailure, "N-API environment creation failed");
+  }
+  if (!EdgeAttachEnvironmentForRuntime(env, nullptr) ||
+      EdgeRuntimePlatformInstallHooks(env) != napi_ok) {
+    (void)unofficial_napi_release_env(env_scope);
+    return Fail(kEngineFailure, "runtime environment attachment failed");
+  }
+
+  g_reactor.env = env;
+  g_reactor.env_scope = env_scope;
+  g_reactor.phase = ReactorPhase::kCreated;
+  g_reactor.last_error.clear();
+  return kOk;
+}
+
+__attribute__((export_name("agentos_node_runtime_bootstrap")))
+int32_t AgentOsNodeRuntimeBootstrap(const uint8_t* bytes, uint32_t length) {
+  if (g_reactor.phase != ReactorPhase::kCreated) {
+    return Fail(kInvalidState, "runtime bootstrap requires the created state");
+  }
+  std::string source;
+  if (!CopySource(bytes, length, &source)) {
+    return Fail(length > kMaxSourceBytes ? kResourceLimit : kInvalidArgument,
+                "bootstrap source is empty, malformed, or exceeds 8 MiB");
+  }
+
+  std::string error;
+  const int exit_code =
+      EdgeRunScriptSourceWithLoop(g_reactor.env, source.c_str(), &error, false);
+  if (exit_code != 0) {
+    return Fail(kScriptFailure,
+                error.empty() ? "Node bootstrap failed" : std::move(error));
+  }
+  g_reactor.phase = ReactorPhase::kBootstrapped;
+  g_reactor.last_error.clear();
+  return kOk;
+}
+
+__attribute__((export_name("agentos_node_runtime_run")))
+int32_t AgentOsNodeRuntimeRun(const uint8_t* bytes, uint32_t length) {
+  if (g_reactor.phase != ReactorPhase::kBootstrapped) {
+    return Fail(kInvalidState, "runtime run requires the bootstrapped state");
+  }
+  std::string source;
+  if (!CopySource(bytes, length, &source)) {
+    return Fail(length > kMaxSourceBytes ? kResourceLimit : kInvalidArgument,
+                "script source is empty, malformed, or exceeds 8 MiB");
+  }
+
+  g_reactor.phase = ReactorPhase::kRunning;
+  std::string error;
+  const int exit_code =
+      EdgeRunScriptInInitializedRuntime(g_reactor.env, source.c_str(), &error, true);
+  if (g_reactor.phase == ReactorPhase::kInterrupted) {
+    return Fail(kInterrupted, "runtime execution was interrupted");
+  }
+  g_reactor.phase = ReactorPhase::kBootstrapped;
+  if (exit_code != 0) {
+    return Fail(kScriptFailure,
+                error.empty() ? "Node script execution failed" : std::move(error));
+  }
+  g_reactor.last_error.clear();
+  return kOk;
+}
+
+__attribute__((export_name("agentos_node_runtime_interrupt")))
+int32_t AgentOsNodeRuntimeInterrupt() {
+  if (g_reactor.phase != ReactorPhase::kRunning &&
+      g_reactor.phase != ReactorPhase::kBootstrapped) {
+    return Fail(kInvalidState,
+                "runtime interrupt requires the running or bootstrapped state");
+  }
+  g_reactor.phase = ReactorPhase::kInterrupted;
+  EdgeWorkerEnvRequestStop(g_reactor.env);
+  if (uv_loop_t* loop = EdgeGetExistingEnvLoop(g_reactor.env); loop != nullptr) {
+    uv_stop(loop);
+  }
+  const napi_status status = unofficial_napi_terminate_execution(g_reactor.env);
+  if (status != napi_ok) {
+    return Fail(kEngineFailure, "engine execution termination failed");
+  }
+  return kOk;
+}
+
+__attribute__((export_name("agentos_node_runtime_quiescence")))
+int32_t AgentOsNodeRuntimeQuiescence() {
+  if (g_reactor.phase == ReactorPhase::kEmpty ||
+      g_reactor.phase == ReactorPhase::kTearingDown) {
+    return kInvalidState;
+  }
+  return EdgeRuntimeIsQuiescent(g_reactor.env) ? 1 : 0;
+}
+
+__attribute__((export_name("agentos_node_runtime_teardown")))
+int32_t AgentOsNodeRuntimeTeardown() {
+  if (g_reactor.phase == ReactorPhase::kEmpty ||
+      g_reactor.phase == ReactorPhase::kTearingDown) {
+    return Fail(kInvalidState, "runtime teardown requires a live runtime");
+  }
+  g_reactor.phase = ReactorPhase::kTearingDown;
+  EdgeWorkerEnvRequestStop(g_reactor.env);
+  if (uv_loop_t* loop = EdgeGetExistingEnvLoop(g_reactor.env); loop != nullptr) {
+    uv_stop(loop);
+  }
+  (void)unofficial_napi_cancel_terminate_execution(g_reactor.env);
+  EdgeEnvironmentRunCleanup(g_reactor.env);
+  EdgeEnvironmentRunAtExitCallbacks(g_reactor.env);
+  edge_builtin_bytecode::FlushIfDirty();
+  const napi_status release_status = unofficial_napi_release_env(g_reactor.env_scope);
+  ReleaseOutstandingAllocations();
+  ResetState();
+  if (release_status != napi_ok) {
+    return Fail(kEngineFailure, "N-API environment release failed");
+  }
+  g_reactor.last_error.clear();
+  return kOk;
+}
+
+__attribute__((export_name("agentos_node_runtime_alloc")))
+uint8_t* AgentOsNodeRuntimeAlloc(uint32_t bytes) {
+  if (bytes == 0 || bytes > kMaxSourceBytes ||
+      g_reactor.allocation_count == kMaxOutstandingAllocations ||
+      bytes > kMaxOutstandingAllocationBytes - g_reactor.allocated_bytes) {
+    (void)Fail(kResourceLimit,
+               "runtime allocation exceeds the 8 MiB/32-allocation aggregate limit");
+    return nullptr;
+  }
+  uint8_t* pointer = static_cast<uint8_t*>(std::malloc(bytes));
+  if (pointer == nullptr) {
+    (void)Fail(kResourceLimit, "runtime allocation failed");
+    return nullptr;
+  }
+  g_reactor.allocations[g_reactor.allocation_count++] = {pointer, bytes};
+  g_reactor.allocated_bytes += bytes;
+  return pointer;
+}
+
+__attribute__((export_name("agentos_node_runtime_free")))
+int32_t AgentOsNodeRuntimeFree(uint8_t* pointer) {
+  for (size_t index = 0; index < g_reactor.allocation_count; ++index) {
+    if (g_reactor.allocations[index].pointer != pointer) continue;
+    g_reactor.allocated_bytes -= g_reactor.allocations[index].bytes;
+    std::free(pointer);
+    --g_reactor.allocation_count;
+    g_reactor.allocations[index] =
+        g_reactor.allocations[g_reactor.allocation_count];
+    g_reactor.allocations[g_reactor.allocation_count] = {};
+    return kOk;
+  }
+  return Fail(kInvalidArgument,
+              "runtime free rejected an unknown or already-freed pointer");
+}
+
+__attribute__((export_name("agentos_node_runtime_allocated_bytes")))
+uint32_t AgentOsNodeRuntimeAllocatedBytes() {
+  return static_cast<uint32_t>(g_reactor.allocated_bytes);
+}
+
+__attribute__((export_name("agentos_node_runtime_allocation_count")))
+uint32_t AgentOsNodeRuntimeAllocationCount() {
+  return static_cast<uint32_t>(g_reactor.allocation_count);
+}
+
+__attribute__((export_name("agentos_node_runtime_last_error")))
+int32_t AgentOsNodeRuntimeLastError(uint8_t* output, uint32_t capacity) {
+  const size_t required = g_reactor.last_error.size() + 1;
+  if (output == nullptr || capacity < required) {
+    return required > static_cast<size_t>(INT32_MAX)
+               ? kResourceLimit
+               : static_cast<int32_t>(required);
+  }
+  if (!ContainsAllocationRange(output, capacity)) return kInvalidArgument;
+  std::memcpy(output, g_reactor.last_error.data(), g_reactor.last_error.size());
+  output[g_reactor.last_error.size()] = '\0';
+  return static_cast<int32_t>(g_reactor.last_error.size());
+}
+
+}  // extern "C"
