if [ -z "$host" ] || [ -z "$directory" ]; then
  cat << \EOF
usage:
#!/bin/sh
host=$HOST
directory=$DIRECTORY
#make=$MAKE
. "$(dirname -- "$(which -- "$0")")/../os-available/ssh-template"
EOF
  exit 1
fi
make=${make-make}
compression=${compression-z}
tar_c_local=-${compression}cf
tar_x_remote=-${compression}xf
tar_c_remote=-${compression}cf
tar_x_local=-${compression}xf
tar ${tar_c_local} - . |
ssh $host "rm -rf -- \"$directory\" &&
mkdir -p -- \"$directory\" &&
cd \"$directory\" &&
tar $tar_x_remote - &&
$make clean clean-test 1>&2 &&
$make test 1>&2 &&
tar $tar_c_remote - out" |
tar $tar_x_local -
