From 0000000000000000000000000000000000000000 Mon Sep 17 00:00:00 2001
From: agentOS Tests <tests@agentos.invalid>
Date: Thu, 9 Jul 2026 23:45:00 -0700
Subject: [PATCH 10/10] fstests: preserve fs_perms exec access check on WASI

WASI cannot resume a forked linear-memory continuation, and the copied probe is
not a registered agentOS command that can be spawned independently. Check its
execute permission with the effective credentials directly. Native builds
retain fork and exec.
---
 src/fs_perms.c | 5 +++++
 1 file changed, 5 insertions(+)

diff --git a/src/fs_perms.c b/src/fs_perms.c
index 6c89bfe6..68bc7c14 100644
--- a/src/fs_perms.c
+++ b/src/fs_perms.c
@@ -18,6 +18,7 @@
 #include <stdio.h>
 #include <string.h>
 #include <ctype.h>
+#include <fcntl.h>
 #include <sys/stat.h>
 #include <sys/types.h>
 #include <stdlib.h>
@@ -86,6 +87,9 @@ int testfperm(int userId, int groupId, char* fperm) {
     }
 
     if (!strcmp("x", fperm)) {
+#ifdef __wasi__
+	ret = faccessat(AT_FDCWD, "test.file", X_OK, AT_EACCESS) == 0 ? 1 : 0;
+#else
 	int status;
 	pid_t pid;
 
@@ -96,6 +100,7 @@ int testfperm(int userId, int groupId, char* fperm) {
 	}
 	wait(&status);
 	ret = WEXITSTATUS(status);
+#endif
     } else if (!strcmp("t", fperm)) {
 	ret = utime("test.file", NULL) ? 0 : 1;
     } else if (!strcmp("T", fperm)) {
-- 
