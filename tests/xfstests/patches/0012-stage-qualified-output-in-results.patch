diff --git a/common/rc b/common/rc
index c88c0552..d6a7e8fc 100644
--- a/common/rc
+++ b/common/rc
@@ -3890,7 +3890,31 @@ _link_out_file_named()
 {
 	test -n "$seqfull" || _fail "need to set seqfull"
 	test -r "$seqfull.cfg" || _fail "need $seqfull.cfg"
 
+	if [ "$FSTYP" = "agentos" ]; then
+		local suffix=default opts candidate opt found
+		while IFS=: read -r opts candidate; do
+			opts=${opts// /}
+			candidate=${candidate// /}
+			found=true
+			IFS=, read -ra required <<< "$opts"
+			for opt in "${required[@]}"; do
+				case ",$2," in
+				*,"$opt",*) ;;
+				*) found=false; break ;;
+				esac
+			done
+			if $found; then
+				suffix=$candidate
+				break
+			fi
+		done < "$seqfull.cfg"
+		local selected="$(dirname "$1")/$(basename "$1").$suffix"
+		test -r "$selected" || _fail "$(basename $1).$suffix: output file for feature set \"$2\" not found"
+		cat "$selected" > "$seqres.expected" || _fail "$(basename $1).$suffix: could not stage output file"
+		return
+	fi
+
 	local features=$2
 	local suffix=$(FEATURES="$features" perl -e '
 		my %feathash;
