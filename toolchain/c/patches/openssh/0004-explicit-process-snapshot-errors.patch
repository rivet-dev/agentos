+#ifdef AGENTOS_NO_PROCESS_SNAPSHOT
+	fatal_f("ControlPersist detach requires cloning live authenticated "
+	    "process state, which this VM cannot snapshot");
+#endif
+
 	debug_f("backgrounding master process");
 
 	/*
