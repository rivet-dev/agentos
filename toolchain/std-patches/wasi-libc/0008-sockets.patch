+int socket(int domain, int type, int protocol) {
+    uint32_t fd;
+    /* Linux accepts creation flags in the type word, but rejects every bit
+     * outside the low socket-type nibble and SOCK_{NONBLOCK,CLOEXEC}. Keep
+     * that validation in libc so unsupported flags fail before a host fd is
+     * allocated. */
+    if (type & ~(0x0f | SOCK_NONBLOCK | SOCK_CLOEXEC)) {
+        errno = EINVAL;
+        return -1;
+    }
+    uint32_t err = __host_net_socket((uint32_t)domain, (uint32_t)type, (uint32_t)protocol, &fd);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    /* The host sees SOCK_NONBLOCK in the original type and initializes the
+     * socket accordingly. FD_CLOEXEC is libc-owned state used by execve(),
+     * so record it through fcntl just like Linux's atomic socket flag. */
+    if ((type & SOCK_CLOEXEC) && fcntl((int)fd, F_SETFD, FD_CLOEXEC) < 0) {
+        int saved_errno = errno;
+        close((int)fd);
+        errno = saved_errno;
+        return -1;
+    }
+    return (int)fd;
+}
+
+int connect(int sockfd, const struct sockaddr *addr, socklen_t addrlen) {
+    uint32_t validation_err = __host_net_validate_socket((uint32_t)sockfd);
+    if (validation_err != 0) {
+        errno = (int)validation_err;
+        return -1;
+    }
+    char buf[256];
+    errno = 0;
+    int len = sockaddr_to_string(addr, addrlen, buf, sizeof(buf));
+    if (len < 0 || (size_t)len >= sizeof(buf)) {
+        if (len >= 0 || errno == 0) errno = (len < 0) ? EAFNOSUPPORT : EINVAL;
+        return -1;
+    }
+    if (strcmp(buf, "unix-autobind") == 0) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    uint32_t err = __host_net_connect((uint32_t)sockfd, (const uint8_t *)buf, (uint32_t)len);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    return 0;
+}
