+WASM_IMPORT("host_net", "net_getpeername")
+uint32_t __host_net_getpeername(uint32_t fd, uint8_t *ret_addr, uint32_t *ret_addr_len);
+
+// host_net.net_bind(fd, addr_ptr, addr_len) -> errno
+WASM_IMPORT("host_net", "net_bind")
+uint32_t __host_net_bind(uint32_t fd, const uint8_t *addr_ptr, uint32_t addr_len);
+
+// host_net.net_listen(fd, backlog) -> errno
+WASM_IMPORT("host_net", "net_listen")
+uint32_t __host_net_listen(uint32_t fd, uint32_t backlog);
+
+// host_net.net_accept(fd, ret_fd, ret_addr, ret_addr_len) -> errno
+WASM_IMPORT("host_net", "net_accept")
+uint32_t __host_net_accept(uint32_t fd, uint32_t *ret_fd, uint8_t *ret_addr, uint32_t *ret_addr_len);
+
+// host_net.net_validate_socket(fd) -> errno without mutating socket state
+WASM_IMPORT("host_net", "net_validate_socket")
+uint32_t __host_net_validate_socket(uint32_t fd);
+
+// host_net.net_validate_accept(fd) -> errno without consuming a connection
+WASM_IMPORT("host_net", "net_validate_accept")
+uint32_t __host_net_validate_accept(uint32_t fd);
+
+// host_net.net_poll(fds_ptr, nfds, timeout_ms, ret_ready) -> errno
+WASM_IMPORT("host_net", "net_poll")
+uint32_t __host_net_poll(uint8_t *fds_ptr, uint32_t nfds, int32_t timeout_ms,
+    uint32_t *ret_ready);
+
+// host_net.net_sendto(fd, buf_ptr, buf_len, flags, addr_ptr, addr_len, ret_sent) -> errno
+WASM_IMPORT("host_net", "net_sendto")
+uint32_t __host_net_sendto(uint32_t fd, const uint8_t *buf_ptr, uint32_t buf_len,
+    uint32_t flags, const uint8_t *addr_ptr, uint32_t addr_len, uint32_t *ret_sent);
+
+// host_net.net_recvfrom(fd, buf_ptr, buf_len, flags, ret_received, ret_addr, ret_addr_len) -> errno
+WASM_IMPORT("host_net", "net_recvfrom")
+uint32_t __host_net_recvfrom(uint32_t fd, uint8_t *buf_ptr, uint32_t buf_len,
+    uint32_t flags, uint32_t *ret_received, uint8_t *ret_addr, uint32_t *ret_addr_len);
+
+// ---------------------------------------------------------------------------
+// Address serialization helpers (AF_INET, AF_INET6, AF_UNIX)
+// ---------------------------------------------------------------------------
+
+// Serialize a sockaddr to a string: "host:port" for inet, "unix:<path>" for unix.
+// The explicit Unix prefix keeps paths containing ':' unambiguous on the host wire.
+// Returns length written (not counting NUL), or -1 on error.
+static int sockaddr_to_string(const struct sockaddr *addr, socklen_t addrlen,
+                              char *buf, size_t buflen) {
+    if (addrlen < (socklen_t)sizeof(addr->sa_family)) {
+        errno = EINVAL;
+        return -1;
+    }
+    if (addr == NULL) {
+        errno = EFAULT;
+        return -1;
+    }
+    if (addr->sa_family == AF_INET) {
+        if (addrlen < (socklen_t)sizeof(struct sockaddr_in)) {
+            errno = EINVAL;
+            return -1;
+        }
+        const struct sockaddr_in *sin = (const struct sockaddr_in *)addr;
+        char ip[INET_ADDRSTRLEN];
+        inet_ntop(AF_INET, &sin->sin_addr, ip, sizeof(ip));
+        unsigned int port = ntohs(sin->sin_port);
+        return snprintf(buf, buflen, "%s:%u", ip, port);
+    } else if (addr->sa_family == AF_INET6) {
+        if (addrlen < (socklen_t)sizeof(struct sockaddr_in6)) {
+            errno = EINVAL;
+            return -1;
+        }
+        const struct sockaddr_in6 *sin6 = (const struct sockaddr_in6 *)addr;
+        char ip[INET6_ADDRSTRLEN];
+        inet_ntop(AF_INET6, &sin6->sin6_addr, ip, sizeof(ip));
+        unsigned int port = ntohs(sin6->sin6_port);
+        return snprintf(buf, buflen, "%s:%u", ip, port);
+    } else if (addr->sa_family == AF_UNIX) {
+        const struct sockaddr_un *sun = (const struct sockaddr_un *)addr;
+        const size_t path_offset = __builtin_offsetof(struct sockaddr_un, sun_path);
+        if (addrlen < (socklen_t)path_offset) {
+            errno = EINVAL;
+            return -1;
+        }
+        size_t supplied = (size_t)addrlen - path_offset;
+        if (supplied > sizeof(sun->sun_path)) {
+            /* wasi-libc aligns sockaddr_un to 16 bytes, leaving two bytes of
+             * tail padding after sun_path. Linux accepts callers (including
+             * OpenSSH unix_listener) that pass sizeof(sockaddr_un); ignore
+             * only that ABI padding while still rejecting every genuinely
+             * overlong addrlen. */
+            if (addrlen == (socklen_t)sizeof(*sun))
+                supplied = sizeof(sun->sun_path);
+            else {
+                errno = EINVAL;
+                return -1;
+            }
+        }
+        if (supplied == 0) {
+            static const char autobind[] = "unix-autobind";
+            if (sizeof(autobind) > buflen) {
+                errno = EINVAL;
+                return -1;
+            }
+            memcpy(buf, autobind, sizeof(autobind));
+            return (int)(sizeof(autobind) - 1);
+        }
+        /* Linux pathname sockets stop at the first NUL even when callers pass
+         * sizeof(sockaddr_un), as OpenSSH's ControlMaster does. Do not forward
+         * the struct's zero padding as part of the virtual path. */
+        if (sun->sun_path[0] == '\0') {
+            static const char abstract_prefix[] = "unix-abstract:";
+            static const char hex[] = "0123456789abcdef";
+            size_t name_len = supplied - 1;
+            size_t output_len = sizeof(abstract_prefix) - 1 + name_len * 2;
+            if (output_len >= buflen) {
+                errno = EINVAL;
+                return -1;
+            }
+            memcpy(buf, abstract_prefix, sizeof(abstract_prefix) - 1);
+            for (size_t i = 0; i < name_len; i++) {
+                unsigned char byte = (unsigned char)sun->sun_path[i + 1];
+                buf[sizeof(abstract_prefix) - 1 + i * 2] = hex[byte >> 4];
+                buf[sizeof(abstract_prefix) + i * 2] = hex[byte & 0x0f];
+            }
+            buf[output_len] = '\0';
+            return (int)output_len;
+        }
+        size_t pathlen = strnlen(sun->sun_path, supplied);
+        static const char path_prefix[] = "unix-path-hex:";
+        static const char hex[] = "0123456789abcdef";
+        size_t output_len = sizeof(path_prefix) - 1 + pathlen * 2;
+        if (output_len >= buflen) return -1;
+        memcpy(buf, path_prefix, sizeof(path_prefix) - 1);
+        for (size_t i = 0; i < pathlen; i++) {
+            unsigned char byte = (unsigned char)sun->sun_path[i];
+            buf[sizeof(path_prefix) - 1 + i * 2] = hex[byte >> 4];
+            buf[sizeof(path_prefix) + i * 2] = hex[byte & 0x0f];
+        }
+        buf[output_len] = '\0';
+        return (int)output_len;
+    }
+    return -1; // unsupported family
+}
+
+// Deserialize an address string into a sockaddr.
+// For "host:port" → sockaddr_in or sockaddr_in6; for paths → sockaddr_un.
+// Returns the actual sockaddr size, or 0 on error.
+static socklen_t string_to_sockaddr(const char *str, struct sockaddr *addr,
+                                    socklen_t addrlen) {
+    const socklen_t path_offset =
+        (socklen_t)__builtin_offsetof(struct sockaddr_un, sun_path);
+    if (strcmp(str, "unix-unnamed") == 0) {
+        struct sockaddr_un sun;
+        memset(&sun, 0, sizeof(sun));
+        sun.sun_family = AF_UNIX;
+        socklen_t copy_len = addrlen < path_offset ? addrlen : path_offset;
+        memcpy(addr, &sun, copy_len);
+        return path_offset;
+    }
+    if (strncmp(str, "unix-abstract:", 14) == 0) {
+        const char *hex = str + 14;
+        size_t hex_len = strlen(hex);
+        if ((hex_len & 1) != 0 || hex_len / 2 > sizeof(((struct sockaddr_un *)0)->sun_path) - 1)
+            return 0;
+        struct sockaddr_un sun;
+        memset(&sun, 0, sizeof(sun));
+        sun.sun_family = AF_UNIX;
+        size_t name_len = hex_len / 2;
+        for (size_t i = 0; i < name_len; i++) {
+            unsigned int value = 0;
+            for (size_t nibble = 0; nibble < 2; nibble++) {
+                unsigned char ch = (unsigned char)hex[i * 2 + nibble];
+                unsigned int digit;
+                if (ch >= '0' && ch <= '9') digit = ch - '0';
+                else if (ch >= 'a' && ch <= 'f') digit = ch - 'a' + 10;
+                else if (ch >= 'A' && ch <= 'F') digit = ch - 'A' + 10;
+                else return 0;
+                value = value * 16 + digit;
+            }
+            sun.sun_path[i + 1] = (char)value;
+        }
+        socklen_t actual = path_offset + 1 + (socklen_t)name_len;
+        socklen_t copy_len = addrlen < actual ? addrlen : actual;
+        memcpy(addr, &sun, copy_len);
+        return actual;
+    }
+    if (strncmp(str, "unix:", 5) == 0) {
+        struct sockaddr_un sun;
+        memset(&sun, 0, sizeof(sun));
+        sun.sun_family = AF_UNIX;
+        size_t pathlen = strlen(str + 5);
+        if (pathlen > sizeof(sun.sun_path)) return 0;
+        memcpy(sun.sun_path, str + 5, pathlen);
+        if (pathlen < sizeof(sun.sun_path)) sun.sun_path[pathlen] = '\0';
+        socklen_t actual = path_offset + (socklen_t)pathlen + 1;
+        socklen_t materialized = actual < (socklen_t)sizeof(sun) ? actual : (socklen_t)sizeof(sun);
+        socklen_t copy_len = addrlen < materialized ? addrlen : materialized;
+        memcpy(addr, &sun, copy_len);
+        if (pathlen == sizeof(sun.sun_path) && addrlen > (socklen_t)sizeof(sun))
+            ((unsigned char *)addr)[sizeof(sun)] = '\0';
+        return actual;
+    }
+
+    // Legacy unprefixed strings without a colon remain Unix paths for wire compatibility.
+    const char *last_colon = strrchr(str, ':');
+    if (last_colon == NULL) {
+        // No colon → Unix domain socket path
+        struct sockaddr_un sun;
+        memset(&sun, 0, sizeof(sun));
+        sun.sun_family = AF_UNIX;
+        size_t pathlen = strlen(str);
+        if (pathlen > sizeof(sun.sun_path)) pathlen = sizeof(sun.sun_path);
+        memcpy(sun.sun_path, str, pathlen);
+        if (pathlen < sizeof(sun.sun_path)) sun.sun_path[pathlen] = '\0';
+        socklen_t actual = path_offset + (socklen_t)pathlen + 1;
+        socklen_t materialized = actual < (socklen_t)sizeof(sun) ? actual : (socklen_t)sizeof(sun);
+        socklen_t copy_len = addrlen < materialized ? addrlen : materialized;
+        memcpy(addr, &sun, copy_len);
+        if (pathlen == sizeof(sun.sun_path) && addrlen > (socklen_t)sizeof(sun))
+            ((unsigned char *)addr)[sizeof(sun)] = '\0';
+        return actual;
+    }
+
+    // Parse host and port
+    char ip[INET6_ADDRSTRLEN];
+    size_t ip_len = (size_t)(last_colon - str);
+    if (ip_len >= sizeof(ip)) ip_len = sizeof(ip) - 1;
+    memcpy(ip, str, ip_len);
+    ip[ip_len] = '\0';
+    unsigned int port = 0;
+    for (const char *p = last_colon + 1; *p >= '0' && *p <= '9'; p++)
+        port = port * 10 + (unsigned int)(*p - '0');
+
+    // Try IPv4 first
+    struct sockaddr_in sin;
+    memset(&sin, 0, sizeof(sin));
+    if (inet_pton(AF_INET, ip, &sin.sin_addr) == 1) {
+        sin.sin_family = AF_INET;
+        sin.sin_port = htons((uint16_t)port);
+        socklen_t copy_len = addrlen < (socklen_t)sizeof(sin) ? addrlen : (socklen_t)sizeof(sin);
+        memcpy(addr, &sin, copy_len);
+        return (socklen_t)sizeof(sin);
+    }
+
+    // Try IPv6
+    struct sockaddr_in6 sin6;
+    memset(&sin6, 0, sizeof(sin6));
+    if (inet_pton(AF_INET6, ip, &sin6.sin6_addr) == 1) {
+        sin6.sin6_family = AF_INET6;
+        sin6.sin6_port = htons((uint16_t)port);
+        socklen_t copy_len = addrlen < (socklen_t)sizeof(sin6) ? addrlen : (socklen_t)sizeof(sin6);
+        memcpy(addr, &sin6, copy_len);
+        return (socklen_t)sizeof(sin6);
+    }
+
+    return 0; // parse failed
+}
