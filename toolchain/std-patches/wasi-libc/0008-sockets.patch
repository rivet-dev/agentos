+// Parse a port number from a string, return -1 on failure
+static int parse_port(const char *s) {
+    if (!s || !*s) return 0;
+    int port = 0;
+    for (; *s; s++) {
+        if (*s < '0' || *s > '9') return -1;
+        port = port * 10 + (*s - '0');
+        if (port > 65535) return -1;
+    }
+    return port;
+}
+
+struct agentos_hosts_address {
+    int family;
+    uint32_t scope_id;
+    char text[64];
+};
