+int accept4(int sockfd, struct sockaddr *restrict addr, socklen_t *restrict addrlen, int flags) {
+    /* Linux resolves the source descriptor before validating creation flags:
+     * accept4(-1, ..., bad_flags) reports EBADF, not EINVAL. */
+    if (fcntl(sockfd, F_GETFD) < 0)
+        return -1;
+    if (flags & ~(SOCK_NONBLOCK | SOCK_CLOEXEC)) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    int accepted = accept(sockfd, addr, addrlen);
+    if (accepted < 0)
+        return -1;
+
+    /* accept4 applies both flags to the returned descriptor. The runtime is
+     * single-threaded, so applying them immediately after accept is
+     * observably equivalent to Linux's atomic creation semantics. */
+    if (flags & SOCK_NONBLOCK) {
+        int status_flags = fcntl(accepted, F_GETFL);
+        if (status_flags < 0 ||
+            fcntl(accepted, F_SETFL, status_flags | O_NONBLOCK) < 0)
+            goto flag_error;
+    }
+    if ((flags & SOCK_CLOEXEC) &&
+        fcntl(accepted, F_SETFD, FD_CLOEXEC) < 0)
+        goto flag_error;
+    return accepted;
+
+flag_error: {
+        int saved_errno = errno;
+        close(accepted);
+        errno = saved_errno;
+        return -1;
+    }
+}
