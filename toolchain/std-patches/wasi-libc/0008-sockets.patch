+ssize_t recv(int sockfd, void *buf, size_t len, int flags) {
+    uint32_t received;
+    uint32_t err = __host_net_recv((uint32_t)sockfd, (uint8_t *)buf, (uint32_t)len, (uint32_t)flags, &received);
+    if (err != 0) {
