+
+static int *host_fd_entries(fd_set *set) {
+    return (int *)((unsigned char *)set + offsetof(fd_set, __fds));
+}
+
+static void host_fd_zero(fd_set *set) {
+    if (set) set->__nfds = 0;
+}
+
+static void host_fd_set(int fd, fd_set *set) {
+    if (!set) return;
+    int *entries = host_fd_entries(set);
+    for (size_t i = 0; i < set->__nfds; i++) {
+        if (entries[i] == fd) return;
+    }
+    /* select() only restores bits that were present in this caller-owned set,
+     * so its output cannot exceed the caller's original allocation. Do not
+     * impose libc's separately compiled FD_SETSIZE on an overrideable caller. */
+    entries[set->__nfds++] = fd;
+}
+
+static int host_pollfd_add_set(struct pollfd *pfds, size_t *count,
+                               int nfds, const fd_set *set, short event,
+                               size_t set_entry_limit) {
+    if (!set) return 0;
+    if (set->__nfds > set_entry_limit) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    const int *entries = host_fd_entries_const(set);
+    for (size_t i = 0; i < set->__nfds; i++) {
+        int fd = entries[i];
+        /* Linux only examines descriptors below nfds. */
+        if (fd < 0 || fd >= nfds) continue;
+
+        size_t j = 0;
+        while (j < *count && pfds[j].fd != fd) j++;
+        if (j == *count) {
+            pfds[j].fd = fd;
+            (*count)++;
+        }
+        pfds[j].events |= event;
+    }
+    return 0;
+}
+
+int select(int nfds, fd_set *restrict readfds, fd_set *restrict writefds,
+           fd_set *restrict exceptfds, struct timeval *restrict timeout) {
+    if (nfds < 0) {
+        errno = EINVAL;
+        return -1;
+    }
+
+    /* Bound the sparse fd_set list lengths by the process descriptor limit.
+     * Linux accepts a numeric nfds above RLIMIT_NOFILE when the actual sets
+     * are sparse, so nfds itself must not drive iteration or allocation. */
+    struct rlimit nofile;
+    if (getrlimit(RLIMIT_NOFILE, &nofile) < 0)
+        return -1;
+    size_t set_entry_limit = nofile.rlim_cur > (rlim_t)SIZE_MAX
+        ? SIZE_MAX : (size_t)nofile.rlim_cur;
+
+    uint64_t timeout_seconds = 0;
+    uint64_t timeout_microseconds = 0;
+    __wasi_timestamp_t timeout_started = 0;
+    int timeout_ms = -1;
+    if (timeout) {
+        if (timeout->tv_sec < 0 || timeout->tv_usec < 0) {
+            errno = EINVAL;
+            return -1;
+        }
+
+        timeout_seconds = (uint64_t)timeout->tv_sec;
+        timeout_microseconds = (uint64_t)timeout->tv_usec;
+        uint64_t extra_seconds = timeout_microseconds / 1000000;
+        timeout_microseconds %= 1000000;
+        if (extra_seconds > (uint64_t)INT64_MAX - timeout_seconds) {
+            errno = EINVAL;
+            return -1;
+        }
+        timeout_seconds += extra_seconds;
+
+        __wasi_errno_t clock_error = __wasi_clock_time_get(
+            __WASI_CLOCKID_MONOTONIC, 1000, &timeout_started);
+        if (clock_error != 0) {
+            errno = clock_error;
+            return -1;
+        }
+    }
+
+    /* Keep the array on the heap and bounded by the three input list lengths.
+     * Iterate sparse caller lists rather than every integer below nfds. */
+    size_t capacity = 0;
+    const fd_set *sets[] = { readfds, writefds, exceptfds };
+    for (size_t i = 0; i < sizeof(sets) / sizeof(sets[0]); i++) {
+        if (!sets[i]) continue;
+        if (sets[i]->__nfds > set_entry_limit ||
+            capacity > SIZE_MAX - sets[i]->__nfds) {
+            errno = EINVAL;
+            return -1;
+        }
+        capacity += sets[i]->__nfds;
+    }
+
+    struct pollfd *pfds = NULL;
+    if (capacity != 0) {
+        pfds = calloc(capacity, sizeof(*pfds));
+        if (!pfds) {
+            errno = ENOMEM;
+            return -1;
+        }
+    }
+
+    size_t count = 0;
+    if (host_pollfd_add_set(pfds, &count, nfds, readfds, POLLIN,
+                            set_entry_limit) < 0 ||
+        host_pollfd_add_set(pfds, &count, nfds, writefds, POLLOUT,
+                            set_entry_limit) < 0 ||
+        host_pollfd_add_set(pfds, &count, nfds, exceptfds, POLLPRI,
+                            set_entry_limit) < 0) {
+        free(pfds);
+        return -1;
+    }
+
+    int ret;
+    for (;;) {
+        if (timeout) {
+            uint64_t milliseconds;
+            if (timeout_seconds > (uint64_t)INT_MAX / 1000) {
+                milliseconds = INT_MAX;
+            } else {
+                milliseconds = timeout_seconds * 1000 +
+                    (timeout_microseconds + 999) / 1000;
+                if (milliseconds > INT_MAX)
+                    milliseconds = INT_MAX;
+            }
+            timeout_ms = (int)milliseconds;
+        }
+
+        ret = poll(pfds, (nfds_t)count, timeout_ms);
+        if (ret < 0) {
+            free(pfds);
+            return -1;
+        }
+        if (!timeout)
+            break;
+
+        __wasi_timestamp_t now;
+        __wasi_errno_t clock_error = __wasi_clock_time_get(
+            __WASI_CLOCKID_MONOTONIC, 1000, &now);
+        if (clock_error != 0) {
+            free(pfds);
+            errno = clock_error;
+            return -1;
+        }
+
+        uint64_t elapsed_microseconds =
+            now >= timeout_started ? (now - timeout_started) / 1000 : 0;
+        uint64_t elapsed_seconds = elapsed_microseconds / 1000000;
+        elapsed_microseconds %= 1000000;
+
+        uint64_t original_seconds = (uint64_t)timeout->tv_sec +
+            (uint64_t)timeout->tv_usec / 1000000;
+        uint64_t original_microseconds =
+            (uint64_t)timeout->tv_usec % 1000000;
+        if (elapsed_seconds > original_seconds ||
+            (elapsed_seconds == original_seconds &&
+             elapsed_microseconds >= original_microseconds)) {
+            timeout_seconds = 0;
+            timeout_microseconds = 0;
+        } else {
+            timeout_seconds = original_seconds - elapsed_seconds;
+            if (elapsed_microseconds > original_microseconds) {
+                timeout_seconds--;
+                timeout_microseconds =
+                    1000000 + original_microseconds - elapsed_microseconds;
+            } else {
+                timeout_microseconds =
+                    original_microseconds - elapsed_microseconds;
+            }
+        }
+
+        if (ret != 0 ||
+            (timeout_seconds == 0 && timeout_microseconds == 0))
+            break;
+    }
+
+    /* poll() reports invalid descriptors per entry; select() reports EBADF
+     * for the whole call and leaves the input sets unspecified. */
+    for (size_t i = 0; i < count; i++) {
+        if (pfds[i].revents & POLLNVAL) {
+            free(pfds);
+            errno = EBADF;
+            return -1;
+        }
+    }
+
+    if (timeout) {
+        timeout->tv_sec = (time_t)timeout_seconds;
+        timeout->tv_usec = (suseconds_t)timeout_microseconds;
+    }
+
+    // Clear fd_sets and scatter results
+    host_fd_zero(readfds);
+    host_fd_zero(writefds);
+    host_fd_zero(exceptfds);
+
+    int ready = 0;
+    for (size_t i = 0; i < count; i++) {
+        int fd = pfds[i].fd;
+        if (readfds && (pfds[i].events & POLLIN) &&
+            (pfds[i].revents & (POLLIN | POLLHUP | POLLERR))) {
+            host_fd_set(fd, readfds);
+            ready++;
+        }
+        if (writefds && (pfds[i].events & POLLOUT) &&
+            (pfds[i].revents & (POLLOUT | POLLERR))) {
+            host_fd_set(fd, writefds);
+            ready++;
+        }
+        if (exceptfds && (pfds[i].events & POLLPRI) &&
+            (pfds[i].revents & POLLPRI)) {
+            host_fd_set(fd, exceptfds);
+            ready++;
+        }
+    }
+    free(pfds);
+    return ready;
+}
