+ssize_t send(int sockfd, const void *buf, size_t len, int flags) {
+    uint32_t sent;
+    uint32_t err = __host_net_send((uint32_t)sockfd, (const uint8_t *)buf, (uint32_t)len, (uint32_t)flags, &sent);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
