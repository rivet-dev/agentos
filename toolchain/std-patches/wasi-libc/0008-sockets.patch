+extern int __agentos_service_port(const char *, int, int);
+extern int __agentos_hosts_lookup_forward(const char *, int,
+    struct agentos_hosts_address *, size_t, size_t *, char *, size_t);
+
+static int resolve_service(const char *service, int socktype, int protocol) {
+    int port = parse_port(service);
+    return port >= 0 ? port :
+        __agentos_service_port(service, socktype, protocol);
+}
+
+// Skip whitespace in JSON parsing
+static const char *skip_ws(const char *p) {
+    while (*p == ' ' || *p == '\t' || *p == '\n' || *p == '\r') p++;
+    return p;
+}
+
+// Parse a JSON string value (expects p pointing at opening quote)
+// Writes into dst (up to dst_len-1 chars), returns pointer past closing quote
+static const char *parse_json_str(const char *p, char *dst, size_t dst_len) {
+    if (*p != '"') return NULL;
+    p++;
+    size_t i = 0;
+    while (*p && *p != '"') {
+        if (i < dst_len - 1) dst[i++] = *p;
+        p++;
+    }
+    if (i < dst_len) dst[i] = '\0';
+    if (*p == '"') p++;
+    return p;
+}
+
+// Allocate and populate one addrinfo entry
+static struct addrinfo *make_addrinfo(const char *addr_str, int family,
+                                      uint32_t scope_id, int port,
+                                      int socktype, int protocol,
+                                      const char *canonical) {
+    size_t sa_len;
+    size_t canonical_len = canonical ? strlen(canonical) + 1 : 0;
+    if (family == AF_INET)
+        sa_len = sizeof(struct sockaddr_in);
+    else if (family == AF_INET6)
+        sa_len = sizeof(struct sockaddr_in6);
+    else
+        return NULL;
+
+    struct addrinfo *ai = calloc(1, sizeof(struct addrinfo) + sa_len + canonical_len);
+    if (!ai) return NULL;
+
+    ai->ai_family = family;
+    ai->ai_socktype = socktype ? socktype : SOCK_STREAM;
+    ai->ai_protocol = protocol ? protocol :
+        ((ai->ai_socktype == SOCK_STREAM) ? IPPROTO_TCP : IPPROTO_UDP);
+    ai->ai_addrlen = sa_len;
+    ai->ai_addr = (struct sockaddr *)((char *)ai + sizeof(struct addrinfo));
+    if (canonical != NULL) {
+        ai->ai_canonname = (char *)ai->ai_addr + sa_len;
+        memcpy(ai->ai_canonname, canonical, canonical_len);
+    }
+
+    if (family == AF_INET) {
+        struct sockaddr_in *sin = (struct sockaddr_in *)ai->ai_addr;
+        sin->sin_family = AF_INET;
+        sin->sin_port = htons((uint16_t)port);
+        inet_pton(AF_INET, addr_str, &sin->sin_addr);
+    } else {
+        struct sockaddr_in6 *sin6 = (struct sockaddr_in6 *)ai->ai_addr;
+        sin6->sin6_family = AF_INET6;
+        sin6->sin6_port = htons((uint16_t)port);
+        sin6->sin6_scope_id = scope_id;
+        inet_pton(AF_INET6, addr_str, &sin6->sin6_addr);
+    }
+    return ai;
+}
+
+static int hosts_addrinfo(const char *host, int requested_family, int port,
+                          int socktype, int protocol, int want_canon,
+                          struct addrinfo **result) {
+    /* One overflow sentinel lets gethostbyname reject >64 answers explicitly
+     * instead of having this lower layer silently truncate at its boundary. */
+    struct agentos_hosts_address addresses[65];
+    char canonical[256];
+    struct addrinfo *head = NULL, *tail = NULL, *entry;
+    size_t count = 0, index;
+    int lookup;
+
+    *result = NULL;
+    lookup = __agentos_hosts_lookup_forward(host, requested_family,
+        addresses, sizeof(addresses) / sizeof(addresses[0]), &count,
+        canonical, sizeof(canonical));
+    if (lookup < 0) return -1;
+    for (index = 0; index < count; index++) {
+        entry = make_addrinfo(addresses[index].text, addresses[index].family,
+            addresses[index].scope_id, port, socktype, protocol,
+            want_canon && index == 0 ? canonical : NULL);
+        if (entry == NULL) {
+            freeaddrinfo(head);
+            return -1;
+        }
+        if (tail != NULL) tail->ai_next = entry;
+        else head = entry;
+        tail = entry;
+    }
+    *result = head;
+    return (int)count;
+}
+
+int getaddrinfo(const char *restrict host, const char *restrict serv,
+                const struct addrinfo *restrict hints, struct addrinfo **restrict res) {
+    if (!host && !serv) return EAI_NONAME;
+
+    const char *host_str = host ? host : "";
+    const char *port_str = serv ? serv : "0";
+
+    int socktype = hints ? hints->ai_socktype : 0;
+    int protocol = hints ? hints->ai_protocol : 0;
+    int port = resolve_service(port_str, socktype, protocol);
+    if (port < 0) return EAI_SERVICE;
+    int family = hints ? hints->ai_family : AF_UNSPEC;
+    uint32_t query_family = 0;
+    if (family == AF_INET) query_family = 4;
+    else if (family == AF_INET6) query_family = 6;
+    else if (family != AF_UNSPEC) return EAI_FAMILY;
+
+    if (host != NULL && *host != '\0') {
+        int hosts_count = hosts_addrinfo(host, family, port, socktype,
+            protocol, hints != NULL && (hints->ai_flags & AI_CANONNAME), res);
+        if (hosts_count < 0) return EAI_MEMORY;
+        if (hosts_count > 0) return 0;
+    }
+
+    // Call host bridge for DNS resolution
+    uint8_t buf[4096];
+    uint32_t buf_len = sizeof(buf) - 1;
+    uint32_t err = __host_net_getaddrinfo(
+        (const uint8_t *)host_str, (uint32_t)strlen(host_str),
+        (const uint8_t *)port_str, (uint32_t)strlen(port_str),
+        query_family,
+        buf, &buf_len);
+    if (err != 0) return EAI_NONAME;
+
+    buf[buf_len] = '\0';
+    const char *json = (const char *)buf;
+
+    // Parse JSON array: [{"addr":"...","family":N}, ...]
+    struct addrinfo *head = NULL;
+    struct addrinfo *tail = NULL;
+    int count = 0;
+
+    const char *p = skip_ws(json);
+    if (*p != '[') return EAI_FAIL;
+    p++;
+
+    while (*p) {
+        p = skip_ws(p);
+        if (*p == ']') break;
+        if (*p == ',') { p++; continue; }
+        if (*p != '{') break;
+        p++;
+
+        char addr_str[64] = {0};
+        int family = 0;
+
+        // Parse object fields
+        while (*p && *p != '}') {
+            p = skip_ws(p);
+            if (*p == ',') { p++; continue; }
+
+            char key[16] = {0};
+            p = parse_json_str(p, key, sizeof(key));
+            if (!p) goto parse_error;
+
+            p = skip_ws(p);
+            if (*p != ':') goto parse_error;
+            p++;
+            p = skip_ws(p);
+
+            if (strcmp(key, "addr") == 0) {
+                p = parse_json_str(p, addr_str, sizeof(addr_str));
+                if (!p) goto parse_error;
+            } else if (strcmp(key, "family") == 0) {
+                family = 0;
+                while (*p >= '0' && *p <= '9') {
+                    family = family * 10 + (*p - '0');
+                    p++;
+                }
+                // Map Node.js family (4/6) to AF_INET/AF_INET6
+                if (family == 4) family = AF_INET;
+                else if (family == 6) family = AF_INET6;
+            } else {
+                // Skip unknown value
+                if (*p == '"') {
+                    char tmp[64];
+                    p = parse_json_str(p, tmp, sizeof(tmp));
+                    if (!p) goto parse_error;
+                } else {
+                    while (*p && *p != ',' && *p != '}') p++;
+                }
+            }
+        }
+        if (*p == '}') p++;
+
+        // Filter by requested family
+        if (hints && hints->ai_family != AF_UNSPEC && hints->ai_family != family)
+            continue;
+
+        struct addrinfo *ai = make_addrinfo(addr_str, family, 0, port, socktype,
+            protocol, NULL);
+        if (!ai) { freeaddrinfo(head); return EAI_MEMORY; }
+
+        if (tail) { tail->ai_next = ai; tail = ai; }
+        else { head = tail = ai; }
+        count++;
+    }
+
+    if (count == 0) return EAI_NONAME;
+    *res = head;
+    return 0;
+
+parse_error:
+    freeaddrinfo(head);
+    return EAI_FAIL;
+}
+
+void freeaddrinfo(struct addrinfo *res) {
+    while (res) {
+        struct addrinfo *next = res->ai_next;
+        free(res);
+        res = next;
+    }
+}
