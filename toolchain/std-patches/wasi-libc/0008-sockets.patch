+int accept(int sockfd, struct sockaddr *restrict addr, socklen_t *restrict addrlen) {
+    uint32_t validation_err = __host_net_validate_accept((uint32_t)sockfd);
+    if (validation_err != 0) {
+        errno = (int)validation_err;
+        return -1;
+    }
+    uint32_t new_fd;
+    uint8_t addr_buf[256];
+    uint32_t addr_buf_len = sizeof(addr_buf) - 1;
+
+    uint32_t err = __host_net_accept((uint32_t)sockfd, &new_fd, addr_buf, &addr_buf_len);
+    if (err != 0) {
+        errno = (int)err;
+        return -1;
+    }
+    /* Linux dequeues the connection before copyout discovers a NULL
+     * addrlen paired with a non-NULL addr. Close the newly accepted fd so
+     * the failed call consumes exactly one pending connection without
+     * leaking its socket description. */
+    if (addr != NULL && addrlen == NULL) {
+        close((int)new_fd);
+        errno = EFAULT;
+        return -1;
+    }
+
+    // Parse remote address string into sockaddr
+    if (addr != NULL && addrlen != NULL) {
+        addr_buf[addr_buf_len] = '\0';
+        socklen_t actual = string_to_sockaddr((const char *)addr_buf, addr, *addrlen);
+        if (actual > 0) *addrlen = actual;
+    }
+
+    return (int)new_fd;
+}
