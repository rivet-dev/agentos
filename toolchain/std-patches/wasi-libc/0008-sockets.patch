+/* FD_SETSIZE is overrideable per application translation unit. Access the
+ * list payload through its stable prefix layout rather than imposing this
+ * libc object's separately compiled array bound. */
+static const int *host_fd_entries_const(const fd_set *set) {
+    return (const int *)((const unsigned char *)set +
+                         offsetof(fd_set, __fds));
