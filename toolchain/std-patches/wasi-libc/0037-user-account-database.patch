Implement the POSIX passwd and group database through host_user.

The VM account database is kernel-owned and may contain multiple live or
configured users and groups. Route name/id lookups, iteration, reentrant APIs,
and getgrouplist through the kernel host service so `/etc/passwd` and
`/etc/group` remain live process-visible sources without executor-local state.

diff --git a/libc-bottom-half/sources/host_user_accounts.c b/libc-bottom-half/sources/host_user_accounts.c
new file mode 100644
index 0000000..a1f4e3d
--- /dev/null
+++ b/libc-bottom-half/sources/host_user_accounts.c
@@ -0,0 +1,310 @@
+#define _GNU_SOURCE
+#include <errno.h>
+#include <grp.h>
+#include <limits.h>
+#include <pwd.h>
+#include <stdint.h>
+#include <stdlib.h>
+#include <string.h>
+
+#define WASM_IMPORT(mod, fn) \
+    __attribute__((__import_module__(mod), __import_name__(fn)))
+#define ACCOUNT_TEXT_MAX 4096
+#define ACCOUNT_GROUP_MEMBERS_MAX 256
+#define ACCOUNT_GROUPS_MAX 256
+
+WASM_IMPORT("host_user", "getpwnam")
+uint32_t __host_getpwnam(const uint8_t *, uint32_t, uint8_t *, uint32_t,
+                         uint32_t *);
+WASM_IMPORT("host_user", "getpwent")
+uint32_t __host_getpwent(uint32_t, uint8_t *, uint32_t, uint32_t *);
+WASM_IMPORT("host_user", "getpwuid")
+uint32_t __host_getpwuid(uint32_t, uint8_t *, uint32_t, uint32_t *);
+WASM_IMPORT("host_user", "getgrnam")
+uint32_t __host_getgrnam(const uint8_t *, uint32_t, uint8_t *, uint32_t,
+                         uint32_t *);
+WASM_IMPORT("host_user", "getgrgid")
+uint32_t __host_getgrgid(uint32_t, uint8_t *, uint32_t, uint32_t *);
+WASM_IMPORT("host_user", "getgrent")
+uint32_t __host_getgrent(uint32_t, uint8_t *, uint32_t, uint32_t *);
+
+typedef uint32_t (*id_lookup)(uint32_t, uint8_t *, uint32_t, uint32_t *);
+typedef uint32_t (*name_lookup)(const uint8_t *, uint32_t, uint8_t *, uint32_t,
+                                uint32_t *);
+
+static int parse_passwd(char *text, size_t length, struct passwd *entry) {
+    char *fields[7];
+    size_t field = 0;
+    fields[0] = text;
+    for (size_t i = 0; i < length && field < 6; i++) {
+        if (text[i] == ':') {
+            text[i] = '\0';
+            fields[++field] = text + i + 1;
+        }
+    }
+    if (field != 6) return EIO;
+    entry->pw_name = fields[0];
+    entry->pw_passwd = fields[1];
+    entry->pw_uid = (uid_t)strtoul(fields[2], 0, 10);
+    entry->pw_gid = (gid_t)strtoul(fields[3], 0, 10);
+    entry->pw_gecos = fields[4];
+    entry->pw_dir = fields[5];
+    entry->pw_shell = fields[6];
+    return 0;
+}
+
+static int finish_passwd(uint32_t error, char *temporary, uint32_t length,
+                         struct passwd *entry, char *buffer, size_t size,
+                         struct passwd **result) {
+    *result = 0;
+    if (error == ENOENT) return 0;
+    if (error != 0) return (int)error;
+    if (length >= ACCOUNT_TEXT_MAX) return EOVERFLOW;
+    if ((size_t)length + 1 > size) return ERANGE;
+    memcpy(buffer, temporary, length);
+    buffer[length] = '\0';
+    int parsed = parse_passwd(buffer, length, entry);
+    if (parsed != 0) return parsed;
+    *result = entry;
+    return 0;
+}
+
+static int passwd_by_id(id_lookup lookup, uint32_t value,
+                        struct passwd *entry, char *buffer, size_t size,
+                        struct passwd **result) {
+    char temporary[ACCOUNT_TEXT_MAX];
+    uint32_t length = 0;
+    uint32_t error = lookup(value, (uint8_t *)temporary, sizeof temporary - 1,
+                            &length);
+    return finish_passwd(error, temporary, length, entry, buffer, size, result);
+}
+
+static int passwd_by_name(name_lookup lookup, const char *name,
+                          struct passwd *entry, char *buffer, size_t size,
+                          struct passwd **result) {
+    char temporary[ACCOUNT_TEXT_MAX];
+    uint32_t length = 0;
+    uint32_t error = lookup((const uint8_t *)name, (uint32_t)strlen(name),
+                            (uint8_t *)temporary, sizeof temporary - 1, &length);
+    return finish_passwd(error, temporary, length, entry, buffer, size, result);
+}
+
+static struct passwd passwd_entry;
+static char passwd_buffer[ACCOUNT_TEXT_MAX];
+static uint32_t passwd_index;
+
+struct passwd *getpwnam(const char *name) {
+    struct passwd *result;
+    int error = passwd_by_name(__host_getpwnam, name, &passwd_entry,
+                               passwd_buffer, sizeof passwd_buffer, &result);
+    if (error != 0) errno = error;
+    return error == 0 ? result : 0;
+}
+
+struct passwd *getpwent(void) {
+    struct passwd *result;
+    int error = passwd_by_id(__host_getpwent, passwd_index, &passwd_entry,
+                             passwd_buffer, sizeof passwd_buffer, &result);
+    if (error != 0) { errno = error; return 0; }
+    if (result) passwd_index++;
+    return result;
+}
+
+void setpwent(void) { passwd_index = 0; }
+void endpwent(void) { passwd_index = 0; }
+
+int getpwuid_r(uid_t uid, struct passwd *entry, char *buffer, size_t size,
+               struct passwd **result) {
+    int error = passwd_by_id(__host_getpwuid, (uint32_t)uid, entry, buffer,
+                             size, result);
+    if (error != 0) errno = error;
+    return error;
+}
+
+int getpwnam_r(const char *name, struct passwd *entry, char *buffer, size_t size,
+               struct passwd **result) {
+    int error = passwd_by_name(__host_getpwnam, name, entry, buffer, size,
+                               result);
+    if (error != 0) errno = error;
+    return error;
+}
+
+static size_t group_member_count(const char *text, size_t length) {
+    const char *members = text;
+    for (int separators = 0; separators < 3; separators++) {
+        members = memchr(members, ':', length - (size_t)(members - text));
+        if (!members) return SIZE_MAX;
+        members++;
+    }
+    if (*members == '\0') return 0;
+    size_t count = 1;
+    for (const char *cursor = members; *cursor; cursor++)
+        if (*cursor == ',') count++;
+    return count;
+}
+
+static int parse_group(char *text, size_t length, struct group *entry,
+                       char **members, size_t member_capacity) {
+    char *fields[4];
+    size_t field = 0;
+    fields[0] = text;
+    for (size_t i = 0; i < length && field < 3; i++) {
+        if (text[i] == ':') {
+            text[i] = '\0';
+            fields[++field] = text + i + 1;
+        }
+    }
+    if (field != 3) return EIO;
+    entry->gr_name = fields[0];
+    entry->gr_passwd = fields[1];
+    entry->gr_gid = (gid_t)strtoul(fields[2], 0, 10);
+    entry->gr_mem = members;
+    size_t count = 0;
+    char *cursor = fields[3];
+    while (*cursor) {
+        if (count >= member_capacity) return ERANGE;
+        members[count++] = cursor;
+        char *comma = strchr(cursor, ',');
+        if (!comma) break;
+        *comma = '\0';
+        cursor = comma + 1;
+    }
+    members[count] = 0;
+    return 0;
+}
+
+static int finish_group(uint32_t error, char *temporary, uint32_t length,
+                        struct group *entry, char *buffer, size_t size,
+                        struct group **result) {
+    *result = 0;
+    if (error == ENOENT) return 0;
+    if (error != 0) return (int)error;
+    if (length >= ACCOUNT_TEXT_MAX) return EOVERFLOW;
+    temporary[length] = '\0';
+    size_t member_count = group_member_count(temporary, length);
+    if (member_count == SIZE_MAX) return EIO;
+    if (member_count > ACCOUNT_GROUP_MEMBERS_MAX) return EOVERFLOW;
+    size_t strings_size = (size_t)length + 1;
+    size_t alignment_padding =
+        (sizeof(char *) - strings_size % sizeof(char *)) % sizeof(char *);
+    size_t members_size = (member_count + 1) * sizeof(char *);
+    if (strings_size > size || alignment_padding > size - strings_size ||
+        members_size > size - strings_size - alignment_padding)
+        return ERANGE;
+    uintptr_t aligned =
+        (uintptr_t)(buffer + strings_size + alignment_padding);
+    memcpy(buffer, temporary, length + 1);
+    int parsed = parse_group(buffer, length, entry, (char **)aligned,
+                             member_count);
+    if (parsed != 0) return parsed;
+    *result = entry;
+    return 0;
+}
+
+static int group_by_id(id_lookup lookup, uint32_t value, struct group *entry,
+                       char *buffer, size_t size, struct group **result) {
+    char temporary[ACCOUNT_TEXT_MAX];
+    uint32_t length = 0;
+    uint32_t error = lookup(value, (uint8_t *)temporary, sizeof temporary - 1,
+                            &length);
+    return finish_group(error, temporary, length, entry, buffer, size, result);
+}
+
+static int group_by_name(name_lookup lookup, const char *name,
+                         struct group *entry, char *buffer, size_t size,
+                         struct group **result) {
+    char temporary[ACCOUNT_TEXT_MAX];
+    uint32_t length = 0;
+    uint32_t error = lookup((const uint8_t *)name, (uint32_t)strlen(name),
+                            (uint8_t *)temporary, sizeof temporary - 1, &length);
+    return finish_group(error, temporary, length, entry, buffer, size, result);
+}
+
+static struct group group_entry;
+static char group_buffer[ACCOUNT_TEXT_MAX +
+                         (ACCOUNT_GROUP_MEMBERS_MAX + 1) * sizeof(char *)];
+static uint32_t group_index;
+
+struct group *getgrgid(gid_t gid) {
+    struct group *result;
+    int error = group_by_id(__host_getgrgid, (uint32_t)gid, &group_entry,
+                            group_buffer, sizeof group_buffer, &result);
+    if (error != 0) errno = error;
+    return error == 0 ? result : 0;
+}
+
+struct group *getgrnam(const char *name) {
+    struct group *result;
+    int error = group_by_name(__host_getgrnam, name, &group_entry, group_buffer,
+                              sizeof group_buffer, &result);
+    if (error != 0) errno = error;
+    return error == 0 ? result : 0;
+}
+
+struct group *getgrent(void) {
+    struct group *result;
+    int error = group_by_id(__host_getgrent, group_index, &group_entry,
+                            group_buffer, sizeof group_buffer, &result);
+    if (error != 0) { errno = error; return 0; }
+    if (result) group_index++;
+    return result;
+}
+
+void setgrent(void) { group_index = 0; }
+void endgrent(void) { group_index = 0; }
+
+int getgrgid_r(gid_t gid, struct group *entry, char *buffer, size_t size,
+               struct group **result) {
+    int error = group_by_id(__host_getgrgid, (uint32_t)gid, entry, buffer,
+                            size, result);
+    if (error != 0) errno = error;
+    return error;
+}
+
+int getgrnam_r(const char *name, struct group *entry, char *buffer, size_t size,
+               struct group **result) {
+    int error = group_by_name(__host_getgrnam, name, entry, buffer, size, result);
+    if (error != 0) errno = error;
+    return error;
+}
+
+static int group_has_member(const struct group *entry, const char *user) {
+    for (char **member = entry->gr_mem; member && *member; member++)
+        if (strcmp(*member, user) == 0) return 1;
+    return 0;
+}
+
+int getgrouplist(const char *user, gid_t primary, gid_t *groups, int *ngroups) {
+    if (!user || !ngroups || *ngroups < 0) { errno = EINVAL; return -1; }
+    gid_t found[ACCOUNT_GROUPS_MAX];
+    size_t count = 0;
+    found[count++] = primary;
+    int database_ended = 0;
+    for (uint32_t index = 0; index < ACCOUNT_GROUPS_MAX; index++) {
+        struct group *entry;
+        int error = group_by_id(__host_getgrent, index, &group_entry,
+                                group_buffer, sizeof group_buffer, &entry);
+        if (error != 0) { errno = error; return -1; }
+        if (!entry) { database_ended = 1; break; }
+        if (!group_has_member(entry, user)) continue;
+        size_t existing = 0;
+        while (existing < count && found[existing] != entry->gr_gid) existing++;
+        if (existing == count) {
+            if (count == ACCOUNT_GROUPS_MAX) { errno = EOVERFLOW; return -1; }
+            found[count++] = entry->gr_gid;
+        }
+    }
+    if (!database_ended) {
+        struct group *extra;
+        int error = group_by_id(__host_getgrent, ACCOUNT_GROUPS_MAX,
+                                &group_entry, group_buffer,
+                                sizeof group_buffer, &extra);
+        if (error != 0) { errno = error; return -1; }
+        if (extra) { errno = EOVERFLOW; return -1; }
+    }
+    int capacity = *ngroups;
+    int copied = capacity < (int)count ? capacity : (int)count;
+    for (int i = 0; i < copied; i++) groups[i] = found[i];
+    *ngroups = (int)count;
+    return capacity < (int)count ? -1 : (int)count;
+}
