Provide group lookup compatibility entry points in AgentOS wasi-libc.

Tree links getgrgid() for optional `-g` group-name output. AgentOS projects a
live /etc/group database, so lookups must observe guest edits instead of using
fixed runtime stubs. The parser lives in the shared libc override and these
entry points provide the standard reentrant and non-reentrant surfaces.

diff --git a/libc-bottom-half/sources/host_resource_user.c b/libc-bottom-half/sources/host_resource_user.c
index 8d91a2f..aa78a47 100644
--- a/libc-bottom-half/sources/host_resource_user.c
+++ b/libc-bottom-half/sources/host_resource_user.c
@@ -2,6 +2,8 @@
 
 #include <errno.h>
+#include <grp.h>
+#include <stddef.h>
 #include <stdint.h>
 #include <string.h>
 #include <sys/resource.h>
 #include <unistd.h>
@@ -68,6 +70,40 @@ int getgroups(int size, gid_t list[]) {
     list[0] = getgid();
     return 1;
 }
 #endif
 
+#ifdef AGENTOS_WASI_LIBC_LEGACY_USER_SHIMS
+int __agentos_group_lookup(const char *, gid_t, int, struct group *, char *,
+                           size_t, struct group **);
+
+static struct group group_entry;
+static char group_buffer[4096];
+
+struct group *getgrgid(gid_t gid) {
+    struct group *result = NULL;
+    int error = __agentos_group_lookup(NULL, gid, 0, &group_entry,
+        group_buffer, sizeof(group_buffer), &result);
+    errno = error;
+    return error == 0 ? result : NULL;
+}
+
+struct group *getgrnam(const char *name) {
+    struct group *result = NULL;
+    int error = __agentos_group_lookup(name, 0, 1, &group_entry,
+        group_buffer, sizeof(group_buffer), &result);
+    errno = error;
+    return error == 0 ? result : NULL;
+}
+
+int getgrgid_r(gid_t gid, struct group *grp, char *buf, size_t buflen,
+               struct group **result) {
+    return __agentos_group_lookup(NULL, gid, 0, grp, buf, buflen, result);
+}
+
+int getgrnam_r(const char *name, struct group *grp, char *buf, size_t buflen,
+               struct group **result) {
+    return __agentos_group_lookup(name, 0, 1, grp, buf, buflen, result);
+}
+#endif
+
