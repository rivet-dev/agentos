Carry POSIX O_DIRECT intent across WASI path_open.

WASI Preview 1 has no direct-I/O open flag. Publish the intent through a
one-shot AgentOS host import immediately before wasi-libc performs path_open;
the managed runner consumes it when opening the kernel-backed descriptor.

diff --git a/libc-bottom-half/headers/public/__header_fcntl.h b/libc-bottom-half/headers/public/__header_fcntl.h
index 8c28e2d..18f45a1 100644
--- a/libc-bottom-half/headers/public/__header_fcntl.h
+++ b/libc-bottom-half/headers/public/__header_fcntl.h
@@ -14,6 +14,7 @@
 #define O_EXCL (__WASI_OFLAGS_EXCL << 12)
 #define O_TRUNC (__WASI_OFLAGS_TRUNC << 12)
 
+#define O_DIRECT   (0x20000000)
 #define O_NOFOLLOW (0x01000000)
 #define O_EXEC     (0x02000000)
 #define O_RDONLY   (0x04000000)
