+static int host_path_chown(int fd, const char *path, uid_t uid, gid_t gid,
+                           int follow_symlinks) {
+    uint32_t current_uid, current_gid;
+    uint32_t result = __agentos_host_path_owner(
+        (uint32_t)fd, path, strlen(path), (uint32_t)follow_symlinks,
+        &current_uid, &current_gid);
+    if (result != 0) return ownership_errno_from_host_result(result);
+    return ownership_errno_from_host_result(__agentos_host_path_chown(
+        (uint32_t)fd, path, strlen(path),
+        preserved_id((uint32_t)uid, current_uid),
+        preserved_id((uint32_t)gid, current_gid),
+        (uint32_t)follow_symlinks));
+}
+
+int chown(const char *path, uid_t uid, gid_t gid) {
+    char *relative_path;
+    int dirfd = find_relpath(path, &relative_path);
+    if (dirfd == -1) { errno = ENOENT; return -1; }
+    return host_path_chown(dirfd, relative_path, uid, gid, 1);
+}
+
+int lchown(const char *path, uid_t uid, gid_t gid) {
+    char *relative_path;
+    int dirfd = find_relpath(path, &relative_path);
+    if (dirfd == -1) { errno = ENOENT; return -1; }
+    return host_path_chown(dirfd, relative_path, uid, gid, 0);
+}
+
+int fchown(int fd, uid_t uid, gid_t gid) {
+    uint32_t current_uid, current_gid;
+    uint32_t result = __agentos_host_fd_owner(
+        (uint32_t)fd, &current_uid, &current_gid);
+    if (result != 0) return ownership_errno_from_host_result(result);
+    return ownership_errno_from_host_result(__agentos_host_fd_chown(
+        (uint32_t)fd, preserved_id((uint32_t)uid, current_uid),
+        preserved_id((uint32_t)gid, current_gid)));
+}
+
+int fchownat(int fd, const char *path, uid_t uid, gid_t gid, int flag) {
+    int supported = AT_SYMLINK_NOFOLLOW;
+#ifdef AT_EMPTY_PATH
+    supported |= AT_EMPTY_PATH;
+#endif
+    if ((flag & ~supported) != 0) { errno = EINVAL; return -1; }
+#ifdef AT_EMPTY_PATH
+    if (path[0] == '\0' && (flag & AT_EMPTY_PATH) != 0)
+        return fchown(fd, uid, gid);
+#endif
+    return host_path_chown(fd, path, uid, gid,
+                           (flag & AT_SYMLINK_NOFOLLOW) == 0);
+}
