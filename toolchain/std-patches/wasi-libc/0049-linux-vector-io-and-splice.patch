diff --git a/libc-bottom-half/sources/preadv2.c b/libc-bottom-half/sources/preadv2.c
new file mode 100644
index 0000000..b1e1b63
--- /dev/null
+++ b/libc-bottom-half/sources/preadv2.c
@@ -0,0 +1,12 @@
+#define _GNU_SOURCE
+#include <errno.h>
+#include <sys/uio.h>
+
+ssize_t preadv2(int fd, const struct iovec *iov, int count, off_t offset,
+                int flags) {
+  if (flags != 0) {
+    errno = EOPNOTSUPP;
+    return -1;
+  }
+  return preadv(fd, iov, count, offset);
+}
