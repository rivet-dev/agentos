Implement POSIX credential transitions and supplementary groups through host_user.

The AgentOS kernel owns process credentials. The earlier OpenSSH compatibility
patch exposes the standard declarations; route every operation through the same
live process identity used by Rust guests.

diff --git a/libc-bottom-half/sources/host_user_credentials.c b/libc-bottom-half/sources/host_user_credentials.c
new file mode 100644
index 0000000..8ad5e50
--- /dev/null
+++ b/libc-bottom-half/sources/host_user_credentials.c
@@ -0,0 +1,96 @@
+#include <errno.h>
+#include <stdint.h>
+#include <stddef.h>
+#include <unistd.h>
+
+#define WASM_IMPORT(mod, fn) \
+    __attribute__((__import_module__(mod), __import_name__(fn)))
+
+#define DECLARE_SET_ID(name, type) \
+    WASM_IMPORT("host_user", #name) uint32_t __host_##name(uint32_t value); \
+    int name(type value) { \
+        uint32_t error = __host_##name((uint32_t)value); \
+        if (error != 0) { errno = (int)error; return -1; } \
+        return 0; \
+    }
+
+WASM_IMPORT("host_user", "getresuid")
+uint32_t __host_getresuid(uint32_t *uid, uint32_t *euid, uint32_t *suid);
+WASM_IMPORT("host_user", "getresgid")
+uint32_t __host_getresgid(uint32_t *gid, uint32_t *egid, uint32_t *sgid);
+WASM_IMPORT("host_user", "setreuid")
+uint32_t __host_setreuid(uint32_t uid, uint32_t euid);
+WASM_IMPORT("host_user", "setresuid")
+uint32_t __host_setresuid(uint32_t uid, uint32_t euid, uint32_t suid);
+WASM_IMPORT("host_user", "setregid")
+uint32_t __host_setregid(uint32_t gid, uint32_t egid);
+WASM_IMPORT("host_user", "setresgid")
+uint32_t __host_setresgid(uint32_t gid, uint32_t egid, uint32_t sgid);
+WASM_IMPORT("host_user", "getgroups")
+uint32_t __host_getgroups(uint32_t capacity, uint32_t *groups, uint32_t *count);
+WASM_IMPORT("host_user", "setgroups")
+uint32_t __host_setgroups(uint32_t count, const uint32_t *groups);
+
+DECLARE_SET_ID(setuid, uid_t)
+DECLARE_SET_ID(seteuid, uid_t)
+DECLARE_SET_ID(setgid, gid_t)
+DECLARE_SET_ID(setegid, gid_t)
+
+static int credential_result(uint32_t error) {
+    if (error == 0) return 0;
+    errno = (int)error;
+    return -1;
+}
+
+int getresuid(uid_t *uid, uid_t *euid, uid_t *suid) {
+    uint32_t real, effective, saved;
+    uint32_t error = __host_getresuid(&real, &effective, &saved);
+    if (error != 0) return credential_result(error);
+    if (uid) *uid = (uid_t)real;
+    if (euid) *euid = (uid_t)effective;
+    if (suid) *suid = (uid_t)saved;
+    return 0;
+}
+
+int getresgid(gid_t *gid, gid_t *egid, gid_t *sgid) {
+    uint32_t real, effective, saved;
+    uint32_t error = __host_getresgid(&real, &effective, &saved);
+    if (error != 0) return credential_result(error);
+    if (gid) *gid = (gid_t)real;
+    if (egid) *egid = (gid_t)effective;
+    if (sgid) *sgid = (gid_t)saved;
+    return 0;
+}
+
+int setreuid(uid_t uid, uid_t euid) {
+    return credential_result(__host_setreuid((uint32_t)uid, (uint32_t)euid));
+}
+
+int setresuid(uid_t uid, uid_t euid, uid_t suid) {
+    return credential_result(__host_setresuid(
+        (uint32_t)uid, (uint32_t)euid, (uint32_t)suid));
+}
+
+int setregid(gid_t gid, gid_t egid) {
+    return credential_result(__host_setregid((uint32_t)gid, (uint32_t)egid));
+}
+
+int setresgid(gid_t gid, gid_t egid, gid_t sgid) {
+    return credential_result(__host_setresgid(
+        (uint32_t)gid, (uint32_t)egid, (uint32_t)sgid));
+}
+
+int getgroups(int size, gid_t groups[]) {
+    if (size < 0) { errno = EINVAL; return -1; }
+    uint32_t count = 0;
+    uint32_t error = __host_getgroups(
+        (uint32_t)size, (uint32_t *)groups, &count);
+    if (error != 0) return credential_result(error);
+    return (int)count;
+}
+
+int setgroups(size_t size, const gid_t *groups) {
+    if (size > UINT32_MAX) { errno = EINVAL; return -1; }
+    return credential_result(__host_setgroups(
+        (uint32_t)size, (const uint32_t *)groups));
+}
