+#[cfg(target_os = "wasi")]
+mod wasi_entries {
+    const RECORD_BYTES: usize = 4096;
+
+    #[link(wasm_import_module = "host_user")]
+    unsafe extern "C" {
+        fn getpwuid(uid: u32, buf_ptr: *mut u8, buf_len: u32, ret_len: *mut u32) -> u32;
+        fn getgrgid(gid: u32, buf_ptr: *mut u8, buf_len: u32, ret_len: *mut u32) -> u32;
+    }
+
+    fn name_from_record(
+        id: u32,
+        lookup: unsafe extern "C" fn(u32, *mut u8, u32, *mut u32) -> u32,
+    ) -> String {
+        let mut buffer = [0; RECORD_BYTES];
+        let mut len = 0;
+        let errno = unsafe { lookup(id, buffer.as_mut_ptr(), buffer.len() as u32, &mut len) };
+        if errno != 0 || len as usize > buffer.len() {
+            return id.to_string();
+        }
+        std::str::from_utf8(&buffer[..len as usize])
+            .ok()
+            .and_then(|record| record.split(':').next())
+            .filter(|name| !name.is_empty())
+            .map(str::to_owned)
+            .unwrap_or_else(|| id.to_string())
+    }
+
+    pub fn uid2usr(uid: u32) -> String {
+        name_from_record(uid, getpwuid)
+    }
+
+    pub fn gid2grp(gid: u32) -> String {
+        name_from_record(gid, getgrgid)
+    }
+}
