--- a/src/parser.rs
+++ b/src/parser.rs
@@ -1177,6 +1177,32 @@ mod tests {
     }
 
     #[test]
+    fn format_quoted_here_doc_with_unquoted_closing_tag() -> Result<()> {
+        let input = "f() {\ncat >/dev/null <<'ENDL'\nbody\nENDL\n:\n}\n";
+        let tokens = tokenize_str(input)?;
+        let result = super::token_parser::program(
+            &Tokens {
+                tokens: tokens.as_slice(),
+            },
+            &ParserOptions::default(),
+            &SourceInfo::default(),
+        )?;
+
+        let formatted = result.to_string();
+        assert!(formatted.contains("<<'ENDL'\nbody\nENDL\n:\n"));
+
+        let formatted_tokens = tokenize_str(&formatted)?;
+        super::token_parser::program(
+            &Tokens {
+                tokens: formatted_tokens.as_slice(),
+            },
+            &ParserOptions::default(),
+            &SourceInfo::default(),
+        )?;
+        Ok(())
+    }
+
+    #[test]
