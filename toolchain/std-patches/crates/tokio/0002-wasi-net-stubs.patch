# tokio 1.52.3 gates outbound/listener socket constructors (`TcpStream::connect`,
# `TcpListener::bind`) behind the readiness reactor, which wasm32-wasip1 lacks.
# tokio-tungstenite (rmcp's websocket transport) and codex-exec-server reference
# these at COMPILE time even though codex never takes those paths in the VM (it
# forces the HTTP transport; networking is host-brokered). Without these arms the
# wasm build fails E0599 "no function `connect`/`bind`". Add compile-only wasi stubs
# that error at runtime. Companion of 0001-tokio-wasi-process.patch; both reproduce
# the fork's vendored tokio-wasi. Pipeline-only codex WASI port.
--- a/src/net/tcp/stream.rs	2006-07-23 18:21:28.000000000 -0700
+++ b/src/net/tcp/stream.rs	2026-06-23 06:09:30.466512017 -0700
@@ -1581,3 +1581,18 @@
         }
     }
 }
+
+// wasm32-wasip1: `connect` lives in `cfg_not_wasip1!` because there is no readiness
+// reactor for outbound sockets. tokio-tungstenite references `TcpStream::connect` at
+// compile time; codex never takes the websocket connect path in the VM (it forces the
+// HTTP fallback), so a compile-only stub that errors at runtime is sufficient.
+#[cfg(target_os = "wasi")]
+impl TcpStream {
+    pub async fn connect<A: crate::net::ToSocketAddrs>(_addr: A) -> std::io::Result<TcpStream> {
+        Err(std::io::Error::new(
+            std::io::ErrorKind::Unsupported,
+            "tokio::net::TcpStream::connect is unsupported on wasm32-wasip1 \
+             (host-brokered networking; use the HTTP transport)",
+        ))
+    }
+}
--- a/src/net/tcp/listener.rs	2006-07-23 18:21:28.000000000 -0700
+++ b/src/net/tcp/listener.rs	2026-06-23 06:31:35.275303405 -0700
@@ -458,3 +458,15 @@
         }
     }
 }
+
+// wasm32-wasip1: outbound/listener sockets have no readiness reactor; codex-exec-server
+// references TcpListener::bind at compile time but is not on the VM session-turn path.
+#[cfg(target_os = "wasi")]
+impl TcpListener {
+    pub async fn bind<A: crate::net::ToSocketAddrs>(_addr: A) -> std::io::Result<TcpListener> {
+        Err(std::io::Error::new(
+            std::io::ErrorKind::Unsupported,
+            "tokio::net::TcpListener::bind is unsupported on wasm32-wasip1",
+        ))
+    }
+}
