+
+#[cfg(target_os = "wasi")]
+mod wasi_host_fs {
+    use super::{Metadata, MetadataExt, Path};
+
+    mod host_fs {
+        #[link(wasm_import_module = "host_fs")]
+        unsafe extern "C" {
+            pub fn path_mode(
+                fd: u32,
+                path_ptr: *const u8,
+                path_len: u32,
+                follow_symlinks: u32,
+            ) -> u32;
+            pub fn path_rdev(
+                fd: u32,
+                path_ptr: *const u8,
+                path_len: u32,
+                follow_symlinks: u32,
+            ) -> u64;
+        }
+    }
+
+    pub fn mode_for_path(path: &Path, meta: &Metadata, follow_symlinks: bool) -> u32 {
+        let Some(path_str) = path.to_str() else {
+            return meta.mode();
+        };
+        let mode = unsafe {
+            host_fs::path_mode(
+                3,
+                path_str.as_ptr(),
+                path_str.len() as u32,
+                if follow_symlinks { 1 } else { 0 },
+            )
+        };
+        if mode == 0 {
+            meta.mode()
+        } else {
+            mode
+        }
+    }
+
+    pub fn rdev_for_path(path: &Path, follow_symlinks: bool) -> u64 {
+        let Some(path_str) = path.to_str() else {
+            return 0;
+        };
+        unsafe {
+            host_fs::path_rdev(
+                3,
+                path_str.as_ptr(),
+                path_str.len() as u32,
+                if follow_symlinks { 1 } else { 0 },
+            )
+        }
+    }
+}
