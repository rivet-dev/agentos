 fn is_stdout_redirected_to_seekable_file() -> bool {
     let s = stdout_canonicalized();
     let p = Path::new(&s);
     match File::open(p) {
         Ok(mut f) => {
             f.stream_position().is_ok() && f.seek(SeekFrom::End(0)).is_ok() && f.rewind().is_ok()
         }
         Err(_) => false,
     }
 }
+
+#[cfg(target_os = "wasi")]
+fn is_stdout_redirected_to_seekable_file() -> bool {
+    let Ok(handle) = OwnedFileDescriptorOrHandle::from(io::stdout()) else {
+        return false;
+    };
+    let mut file = handle.into_file();
+    file.metadata().is_ok_and(|metadata| metadata.is_file())
+        && file.stream_position().is_ok()
+        && file.seek(SeekFrom::End(0)).is_ok()
+        && file.rewind().is_ok()
+}
