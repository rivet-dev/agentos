{
	"name": "@rivet-dev/agentos-python",
	"version": "0.0.1",
	"description": "AgentOS language execution for Python.",
	"type": "module",
	"license": "Apache-2.0",
	"sideEffects": false,
	"main": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"files": [
		"dist",
		"README.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		}
	},
	"engines": {
		"node": ">=22.0.0"
	},
	"scripts": {
		"build": "tsup src/index.ts",
		"check-types": "tsc --noEmit",
		"test": "vitest run --passWithNoTests"
	},
	"dependencies": {
		"@rivet-dev/agentos-core": "workspace:*"
	},
	"devDependencies": {
		"@types/node": "^22.19.15",
		"tsup": "^8.4.0",
		"typescript": "^5.7.3",
		"vitest": "^2.1.8"
	}
}
