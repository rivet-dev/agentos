{
	"name": "@rivet-dev/agentos-shell",
	"version": "0.2.0-rc.3",
	"private": false,
	"type": "module",
	"bin": {
		"agentos-shell": "./dist/main.js",
		"agent-os-shell": "./dist/main.js"
	},
	"scripts": {
		"build": "tsc",
		"check-types": "tsc --noEmit",
		"shell": "tsx src/main.ts",
		"test": "pnpm build && vitest run --fileParallelism=false"
	},
	"dependencies": {
