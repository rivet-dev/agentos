{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "noEmit": true,
	"baseUrl": ".",
	"paths": {
	  "@rivet-dev/agentos-typescript": ["../typescript/src/index.ts"],
	  "@rivet-dev/agentos-core": ["../core/src/index.ts"],
	  "@rivet-dev/agentos-core/internal/runtime-compat": ["../core/src/runtime-compat.ts"]
	}
  },
  "include": ["src/**/*.ts", "../core/src/cron/long-timeout.d.ts"]
}
